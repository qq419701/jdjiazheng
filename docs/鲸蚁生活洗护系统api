    {
        "data": {
            "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzZWxmQXBwSWQiOiJjbWNscjcxZncwMDAxNnB6YjFxd3FnZHFoIiwiaWF0IjoxNzUyMDY4NjUxLCJleHAiOjE3NTIwNzU4NTF9.GRHDkuy95VT_2lQL1i7iIDdyA36TYH1Px0PpQ9LazkI",
            "tenantId": "cm5njh4dx0006o37os2cxs9b2"
        },
        "code": 0,
        "message": "success",
        "success":     true
    }
