# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jdjiazheng
DB_USER=root
DB_PASSWORD=your_password

# JWT密钥
JWT_SECRET=your_jwt_secret_key_here

# 服务端口
PORT=5500

# 管理员初始密码
ADMIN_DEFAULT_PASSWORD=admin123

# Puppeteer配置
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=30000

# 环境
NODE_ENV=production

# ============================================================
# 业务模块开关（true=开启 / false=关闭）
# 修改后需要重启后端服务才能生效：pm2 restart <进程名>
# 关闭某业务后：该业务的H5卡密验证接口返回"业务未开放"
#               后台管理中该业务的订单Tab/卡密Tab/统计卡片全部隐藏
# ============================================================
# 🏠 家政业务（京东家政预约代下单）
BUSINESS_JIAZHENG_ENABLED=true
# 🧺 洗衣业务（鲸蚁生活洗衣服务）
BUSINESS_XIYIFU_ENABLED=true
# 💳 充值业务（各类会员充值）
BUSINESS_TOPUP_ENABLED=true
# ⚔️ 三角洲业务（三角洲哈夫币充值）
BUSINESS_SJZ_ENABLED=true
